# Board Identity
CONFIG_BOARD_60WKEYBOARD=y

# Hardware Architecture
CONFIG_ARM_MPU=y
CONFIG_PINCTRL=y
CONFIG_GPIO=y

# Bootloader & Flash Settings
CONFIG_USE_DT_CODE_PARTITION=y
CONFIG_BUILD_OUTPUT_UF2=y
CONFIG_MPU_ALLOW_FLASH_WRITE=y
CONFIG_NVS=y
CONFIG_SETTINGS_NVS=y
CONFIG_FLASH=y
CONFIG_FLASH_PAGE_LAYOUT=y
CONFIG_FLASH_MAP=y

# Keyboard Matrix & Features
CONFIG_ZMK_KEYBOARD_NAME="60W Keyboard"
CONFIG_ZMK_USB=y
CONFIG_ZMK_BLE=y

# Per-Key RGB Settings (Using Underglow drivers)
CONFIG_ZMK_RGB_UNDERGLOW=y
CONFIG_WS2812_STRIP=y
CONFIG_SPI=y

# Default RGB Effects
CONFIG_ZMK_RGB_UNDERGLOW_HUE_START=160
CONFIG_ZMK_RGB_UNDERGLOW_SAT_START=100
CONFIG_ZMK_RGB_UNDERGLOW_BRT_START=10
CONFIG_ZMK_RGB_UNDERGLOW_EFF_START=3

# Power Management
# Disable DCDC because custom boards without specific inductors will crash if enabled
CONFIG_SOC_DCDC_NRF52X=n
# Enable Sleep mode to save battery
CONFIG_ZMK_SLEEP=y
CONFIG_ZMK_IDLE_SLEEP_TIMEOUT=900000

# USB Power Output (Required for some USB-C to USB-C cables)
CONFIG_USB_DEVICE_STACK=y
CONFIG_USB_DEVICE_PRODUCT="60W Keyboard"