# Core Hardware Support
CONFIG_ZMK_KEYBOARD_NAME="60wkeyboard"
CONFIG_SOC_SERIES_NRF52X=y
CONFIG_SOC_NRF52840_QIAA=y
CONFIG_BOARD_60WKEYBOARD=y

# Power Management
CONFIG_ZMK_SLEEP=y
CONFIG_ZMK_IDLE_SLEEP_TIMEOUT=900000

# Bluetooth Settings
CONFIG_BT=y
CONFIG_ZMK_BLE=y
CONFIG_BT_CTLR_TX_PWR_PLUS_8=y

# USB Support
CONFIG_ZMK_USB=y

# RGB Underglow and LED Strip
CONFIG_ZMK_RGB_UNDERGLOW=y
CONFIG_WS2812_STRIP=y
CONFIG_SPI=y

# Matrix Driver
CONFIG_ZMK_KSCAN=y
CONFIG_ZMK_KSCAN_MATRIX_POLLING=y