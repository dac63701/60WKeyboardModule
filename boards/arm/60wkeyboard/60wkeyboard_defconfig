CONFIG_SOC_SERIES_NRF52X=y
CONFIG_SOC_NRF52840_QIAA=y
CONFIG_BOARD_60WKEYBOARD=y

# ARM
CONFIG_ARM_MPU=y
CONFIG_MPU_ALLOW_FLASH_WRITE=y

# Pin control
CONFIG_PINCTRL=y

# GPIO
CONFIG_GPIO=y

# Flash / Storage
CONFIG_FLASH=y
CONFIG_FLASH_PAGE_LAYOUT=y
CONFIG_FLASH_MAP=y
CONFIG_NVS=y
CONFIG_SETTINGS_NVS=y

# UF2 bootloader output
CONFIG_USE_DT_CODE_PARTITION=y
CONFIG_BUILD_OUTPUT_UF2=y

# USB — both layers required
CONFIG_USB_DEVICE_STACK=y
CONFIG_ZMK_USB=y

# Bluetooth — both layers required
CONFIG_BT=y
CONFIG_ZMK_BLE=y

# RGB disabled for base build
CONFIG_ZMK_RGB_UNDERGLOW=n
CONFIG_WS2812_STRIP=n